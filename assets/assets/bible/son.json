{
  "bookId": "SON",
  "verses": [
    {
      "id": "SON_1_1",
      "bookId": "SON",
      "bookName": "Cantares",
      "chapter": 1,
      "verseNumber": 1,
      "spanishTranslation": "Cantar de los cantares, el cual es de Salomón.",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "SON_1_2",
      "bookId": "SON",
      "bookName": "Cantares",
      "chapter": 1,
      "verseNumber": 2,
      "spanishTranslation": "¡Oh, si él me besara con besos de su boca!Porque mejores son tus amores que el vino.",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "SON_1_3",
      "bookId": "SON",
      "bookName": "Cantares",
      "chapter": 1,
      "verseNumber": 3,
      "spanishTranslation": "A más del olor de tus suaves ungüentos,Tu nombre es como ungüento derramado;Por eso las doncellas te aman.",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "SON_1_4",
      "bookId": "SON",
      "bookName": "Cantares",
      "chapter": 1,
      "verseNumber": 4,
      "spanishTranslation": "Atráeme; en pos de ti correremos.El rey me ha metido en sus cámaras;Nos gozaremos y alegraremos en ti;Nos acordaremos de tus amores más que del vino;Con razón te aman.",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "SON_1_5",
      "bookId": "SON",
      "bookName": "Cantares",
      "chapter": 1,
      "verseNumber": 5,
      "spanishTranslation": "Morena soy, oh hijas de Jerusalén, pero codiciableComo las tiendas de Cedar,Como las cortinas de Salomón.",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "SON_1_6",
      "bookId": "SON",
      "bookName": "Cantares",
      "chapter": 1,
      "verseNumber": 6,
      "spanishTranslation": "No reparéis en que soy morena,Porque el sol me miró.Los hijos de mi madre se airaron contra mí;Me pusieron a guardar las viñas;Y mi viña, que era mía, no guardé.",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "SON_1_7",
      "bookId": "SON",
      "bookName": "Cantares",
      "chapter": 1,
      "verseNumber": 7,
      "spanishTranslation": "Hazme saber, oh tú a quien ama mi alma,Dónde apacientas, dónde sesteas al mediodía;Pues ¿por qué había de estar yo como erranteJunto a los rebaños de tus compañeros?",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "SON_1_8",
      "bookId": "SON",
      "bookName": "Cantares",
      "chapter": 1,
      "verseNumber": 8,
      "spanishTranslation": "Si tú no lo sabes, oh hermosa entre las mujeres,Ve, sigue las huellas del rebaño,Y apacienta tus cabritas junto a las cabañas de los pastores.",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "SON_1_9",
      "bookId": "SON",
      "bookName": "Cantares",
      "chapter": 1,
      "verseNumber": 9,
      "spanishTranslation": "A yegua de los carros de FaraónTe he comparado, amiga mía.",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "SON_1_10",
      "bookId": "SON",
      "bookName": "Cantares",
      "chapter": 1,
      "verseNumber": 10,
      "spanishTranslation": "Hermosas son tus mejillas entre los pendientes,Tu cuello entre los collares.",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "SON_1_11",
      "bookId": "SON",
      "bookName": "Cantares",
      "chapter": 1,
      "verseNumber": 11,
      "spanishTranslation": "Zarcillos de oro te haremos,Tachonados de plata.",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "SON_1_12",
      "bookId": "SON",
      "bookName": "Cantares",
      "chapter": 1,
      "verseNumber": 12,
      "spanishTranslation": "Mientras el rey estaba en su reclinatorio,Mi nardo dio su olor.",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "SON_1_13",
      "bookId": "SON",
      "bookName": "Cantares",
      "chapter": 1,
      "verseNumber": 13,
      "spanishTranslation": "Mi amado es para mí un manojito de mirra,Que reposa entre mis pechos.",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "SON_1_14",
      "bookId": "SON",
      "bookName": "Cantares",
      "chapter": 1,
      "verseNumber": 14,
      "spanishTranslation": "Racimo de flores de alheña en las viñas de En-gadiEs para mí mi amado.",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "SON_1_15",
      "bookId": "SON",
      "bookName": "Cantares",
      "chapter": 1,
      "verseNumber": 15,
      "spanishTranslation": "He aquí que tú eres hermosa, amiga mía;He aquí eres bella; tus ojos son como palomas.",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "SON_1_16",
      "bookId": "SON",
      "bookName": "Cantares",
      "chapter": 1,
      "verseNumber": 16,
      "spanishTranslation": "He aquí que tú eres hermoso, amado mío, y dulce;Nuestro lecho es de flores.",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "SON_1_17",
      "bookId": "SON",
      "bookName": "Cantares",
      "chapter": 1,
      "verseNumber": 17,
      "spanishTranslation": "Las vigas de nuestra casa son de cedro,Y de ciprés los artesonados.",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "SON_2_1",
      "bookId": "SON",
      "bookName": "Cantares",
      "chapter": 2,
      "verseNumber": 1,
      "spanishTranslation": "Yo soy la rosa de Sarón,Y el lirio de los valles.",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "SON_2_2",
      "bookId": "SON",
      "bookName": "Cantares",
      "chapter": 2,
      "verseNumber": 2,
      "spanishTranslation": "Como el lirio entre los espinos,Así es mi amiga entre las doncellas.",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "SON_2_3",
      "bookId": "SON",
      "bookName": "Cantares",
      "chapter": 2,
      "verseNumber": 3,
      "spanishTranslation": "Como el manzano entre los árboles silvestres,Así es mi amado entre los jóvenes;Bajo la sombra del deseado me senté,Y su fruto fue dulce a mi paladar.",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "SON_2_4",
      "bookId": "SON",
      "bookName": "Cantares",
      "chapter": 2,
      "verseNumber": 4,
      "spanishTranslation": "Me llevó a la casa del banquete,Y su bandera sobre mí fue amor.",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "SON_2_5",
      "bookId": "SON",
      "bookName": "Cantares",
      "chapter": 2,
      "verseNumber": 5,
      "spanishTranslation": "Sustentadme con pasas, confortadme con manzanas;Porque estoy enferma de amor.",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "SON_2_6",
      "bookId": "SON",
      "bookName": "Cantares",
      "chapter": 2,
      "verseNumber": 6,
      "spanishTranslation": "Su izquierda esté debajo de mi cabeza,Y su derecha me abrace.",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "SON_2_7",
      "bookId": "SON",
      "bookName": "Cantares",
      "chapter": 2,
      "verseNumber": 7,
      "spanishTranslation": "Yo os conjuro, oh doncellas de Jerusalén,Por los corzos y por las ciervas del campo,Que no despertéis ni hagáis velar al amor,Hasta que quiera.",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "SON_2_8",
      "bookId": "SON",
      "bookName": "Cantares",
      "chapter": 2,
      "verseNumber": 8,
      "spanishTranslation": "¡La voz de mi amado! He aquí él vieneSaltando sobre los montes,Brincando sobre los collados.",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "SON_2_9",
      "bookId": "SON",
      "bookName": "Cantares",
      "chapter": 2,
      "verseNumber": 9,
      "spanishTranslation": "Mi amado es semejante al corzo,O al cervatillo.Helo aquí, está tras nuestra pared,Mirando por las ventanas,Atisbando por las celosías.",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "SON_2_10",
      "bookId": "SON",
      "bookName": "Cantares",
      "chapter": 2,
      "verseNumber": 10,
      "spanishTranslation": "Mi amado habló, y me dijo:Levántate, oh amiga mía, hermosa mía, y ven.",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "SON_2_11",
      "bookId": "SON",
      "bookName": "Cantares",
      "chapter": 2,
      "verseNumber": 11,
      "spanishTranslation": "Porque he aquí ha pasado el invierno,Se ha mudado, la lluvia se fue;",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "SON_2_12",
      "bookId": "SON",
      "bookName": "Cantares",
      "chapter": 2,
      "verseNumber": 12,
      "spanishTranslation": "Se han mostrado las flores en la tierra,El tiempo de la canción ha venido,Y en nuestro país se ha oído la voz de la tórtola.",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "SON_2_13",
      "bookId": "SON",
      "bookName": "Cantares",
      "chapter": 2,
      "verseNumber": 13,
      "spanishTranslation": "La higuera ha echado sus higos,Y las vides en cierne dieron olor;Levántate, oh amiga mía, hermosa mía, y ven.",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "SON_2_14",
      "bookId": "SON",
      "bookName": "Cantares",
      "chapter": 2,
      "verseNumber": 14,
      "spanishTranslation": "Paloma mía, que estás en los agujeros de la peña, en lo escondido de escarpados parajes,Muéstrame tu rostro, hazme oír tu voz;Porque dulce es la voz tuya, y hermoso tu aspecto.",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "SON_2_15",
      "bookId": "SON",
      "bookName": "Cantares",
      "chapter": 2,
      "verseNumber": 15,
      "spanishTranslation": "Cazadnos las zorras, las zorras pequeñas, que echan a perder las viñas;Porque nuestras viñas están en cierne.",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "SON_2_16",
      "bookId": "SON",
      "bookName": "Cantares",
      "chapter": 2,
      "verseNumber": 16,
      "spanishTranslation": "Mi amado es mío, y yo suya;Él apacienta entre lirios.",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "SON_2_17",
      "bookId": "SON",
      "bookName": "Cantares",
      "chapter": 2,
      "verseNumber": 17,
      "spanishTranslation": "Hasta que apunte el día, y huyan las sombras,Vuélvete, amado mío; sé semejante al corzo, o como el cervatilloSobre los montes de Beter.",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "SON_3_1",
      "bookId": "SON",
      "bookName": "Cantares",
      "chapter": 3,
      "verseNumber": 1,
      "spanishTranslation": "Por las noches busqué en mi lecho al que ama mi alma;Lo busqué, y no lo hallé.",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "SON_3_2",
      "bookId": "SON",
      "bookName": "Cantares",
      "chapter": 3,
      "verseNumber": 2,
      "spanishTranslation": "Y dije: Me levantaré ahora, y rodearé por la ciudad;Por las calles y por las plazasBuscaré al que ama mi alma;Lo busqué, y no lo hallé.",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "SON_3_3",
      "bookId": "SON",
      "bookName": "Cantares",
      "chapter": 3,
      "verseNumber": 3,
      "spanishTranslation": "Me hallaron los guardas que rondan la ciudad,Y les dije: ¿Habéis visto al que ama mi alma?",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "SON_3_4",
      "bookId": "SON",
      "bookName": "Cantares",
      "chapter": 3,
      "verseNumber": 4,
      "spanishTranslation": "Apenas hube pasado de ellos un poco,Hallé luego al que ama mi alma;Lo así, y no lo dejé,Hasta que lo metí en casa de mi madre,Y en la cámara de la que me dio a luz.",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "SON_3_5",
      "bookId": "SON",
      "bookName": "Cantares",
      "chapter": 3,
      "verseNumber": 5,
      "spanishTranslation": "Yo os conjuro, oh doncellas de Jerusalén,Por los corzos y por las ciervas del campo,Que no despertéis ni hagáis velar al amor,Hasta que quiera.",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "SON_3_6",
      "bookId": "SON",
      "bookName": "Cantares",
      "chapter": 3,
      "verseNumber": 6,
      "spanishTranslation": "¿Quién es ésta que sube del desierto como columna de humo,Sahumada de mirra y de inciensoY de todo polvo aromático?",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "SON_3_7",
      "bookId": "SON",
      "bookName": "Cantares",
      "chapter": 3,
      "verseNumber": 7,
      "spanishTranslation": "He aquí es la litera de Salomón;Sesenta valientes la rodean,De los fuertes de Israel.",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "SON_3_8",
      "bookId": "SON",
      "bookName": "Cantares",
      "chapter": 3,
      "verseNumber": 8,
      "spanishTranslation": "Todos ellos tienen espadas, diestros en la guerra;Cada uno su espada sobre su muslo,Por los temores de la noche.",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "SON_3_9",
      "bookId": "SON",
      "bookName": "Cantares",
      "chapter": 3,
      "verseNumber": 9,
      "spanishTranslation": "El rey Salomón se hizo una carrozaDe madera del Líbano.",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "SON_3_10",
      "bookId": "SON",
      "bookName": "Cantares",
      "chapter": 3,
      "verseNumber": 10,
      "spanishTranslation": "Hizo sus columnas de plata,Su respaldo de oro,Su asiento de grana,Su interior recamado de amorPor las doncellas de Jerusalén.",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "SON_3_11",
      "bookId": "SON",
      "bookName": "Cantares",
      "chapter": 3,
      "verseNumber": 11,
      "spanishTranslation": "Salid, oh doncellas de Sion, y ved al rey SalomónCon la corona con que le coronó su madre en el día de su desposorio,Y el día del gozo de su corazón.",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "SON_4_1",
      "bookId": "SON",
      "bookName": "Cantares",
      "chapter": 4,
      "verseNumber": 1,
      "spanishTranslation": "He aquí que tú eres hermosa, amiga mía; he aquí que tú eres hermosa;Tus ojos entre tus guedejas como de paloma;Tus cabellos como manada de cabrasQue se recuestan en las laderas de Galaad.",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "SON_4_2",
      "bookId": "SON",
      "bookName": "Cantares",
      "chapter": 4,
      "verseNumber": 2,
      "spanishTranslation": "Tus dientes como manadas de ovejas trasquiladas,Que suben del lavadero,Todas con crías gemelas,Y ninguna entre ellas estéril.",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "SON_4_3",
      "bookId": "SON",
      "bookName": "Cantares",
      "chapter": 4,
      "verseNumber": 3,
      "spanishTranslation": "Tus labios como hilo de grana,Y tu habla hermosa;Tus mejillas, como cachos de granada detrás de tu velo.",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "SON_4_4",
      "bookId": "SON",
      "bookName": "Cantares",
      "chapter": 4,
      "verseNumber": 4,
      "spanishTranslation": "Tu cuello, como la torre de David, edificada para armería;Mil escudos están colgados en ella,Todos escudos de valientes.",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "SON_4_5",
      "bookId": "SON",
      "bookName": "Cantares",
      "chapter": 4,
      "verseNumber": 5,
      "spanishTranslation": "Tus dos pechos, como gemelos de gacela,Que se apacientan entre lirios.",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "SON_4_6",
      "bookId": "SON",
      "bookName": "Cantares",
      "chapter": 4,
      "verseNumber": 6,
      "spanishTranslation": "Hasta que apunte el día y huyan las sombras,Me iré al monte de la mirra,Y al collado del incienso.",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "SON_4_7",
      "bookId": "SON",
      "bookName": "Cantares",
      "chapter": 4,
      "verseNumber": 7,
      "spanishTranslation": "Toda tú eres hermosa, amiga mía,Y en ti no hay mancha.",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "SON_4_8",
      "bookId": "SON",
      "bookName": "Cantares",
      "chapter": 4,
      "verseNumber": 8,
      "spanishTranslation": "Ven conmigo desde el Líbano, oh esposa mía;Ven conmigo desde el Líbano.Mira desde la cumbre de Amana,Desde la cumbre de Senir y de Hermón,Desde las guaridas de los leones,Desde los montes de los leopardos.",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "SON_4_9",
      "bookId": "SON",
      "bookName": "Cantares",
      "chapter": 4,
      "verseNumber": 9,
      "spanishTranslation": "Prendiste mi corazón, hermana, esposa mía;Has apresado mi corazón con uno de tus ojos,Con una gargantilla de tu cuello.",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "SON_4_10",
      "bookId": "SON",
      "bookName": "Cantares",
      "chapter": 4,
      "verseNumber": 10,
      "spanishTranslation": "¡Cuán hermosos son tus amores, hermana, esposa mía!¡Cuánto mejores que el vino tus amores,Y el olor de tus ungüentos que todas las especias aromáticas!",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "SON_4_11",
      "bookId": "SON",
      "bookName": "Cantares",
      "chapter": 4,
      "verseNumber": 11,
      "spanishTranslation": "Como panal de miel destilan tus labios, oh esposa;Miel y leche hay debajo de tu lengua;Y el olor de tus vestidos como el olor del Líbano.",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "SON_4_12",
      "bookId": "SON",
      "bookName": "Cantares",
      "chapter": 4,
      "verseNumber": 12,
      "spanishTranslation": "Huerto cerrado eres, hermana mía, esposa mía;Fuente cerrada, fuente sellada.",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "SON_4_13",
      "bookId": "SON",
      "bookName": "Cantares",
      "chapter": 4,
      "verseNumber": 13,
      "spanishTranslation": "Tus renuevos son paraíso de granados, con frutos suaves,De flores de alheña y nardos;",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "SON_4_14",
      "bookId": "SON",
      "bookName": "Cantares",
      "chapter": 4,
      "verseNumber": 14,
      "spanishTranslation": "Nardo y azafrán, caña aromática y canela,Con todos los árboles de incienso;Mirra y áloes, con todas las principales especias aromáticas.",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "SON_4_15",
      "bookId": "SON",
      "bookName": "Cantares",
      "chapter": 4,
      "verseNumber": 15,
      "spanishTranslation": "Fuente de huertos,Pozo de aguas vivas,Que corren del Líbano.",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "SON_4_16",
      "bookId": "SON",
      "bookName": "Cantares",
      "chapter": 4,
      "verseNumber": 16,
      "spanishTranslation": "Levántate, Aquilón, y ven, Austro;Soplad en mi huerto, despréndanse sus aromas.Venga mi amado a su huerto,Y coma de su dulce fruta.",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "SON_5_1",
      "bookId": "SON",
      "bookName": "Cantares",
      "chapter": 5,
      "verseNumber": 1,
      "spanishTranslation": "Yo vine a mi huerto, oh hermana, esposa mía;He recogido mi mirra y mis aromas;He comido mi panal y mi miel,Mi vino y mi leche he bebido.Comed, amigos; bebed en abundancia, oh amados.",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "SON_5_2",
      "bookId": "SON",
      "bookName": "Cantares",
      "chapter": 5,
      "verseNumber": 2,
      "spanishTranslation": "Yo dormía, pero mi corazón velaba.Es la voz de mi amado que llama:Abreme, hermana mía, amiga mía, paloma mía, perfecta mía,Porque mi cabeza está llena de rocío,Mis cabellos de las gotas de la noche.",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "SON_5_3",
      "bookId": "SON",
      "bookName": "Cantares",
      "chapter": 5,
      "verseNumber": 3,
      "spanishTranslation": "Me he desnudado de mi ropa; ¿cómo me he de vestir?He lavado mis pies; ¿cómo los he de ensuciar?",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "SON_5_4",
      "bookId": "SON",
      "bookName": "Cantares",
      "chapter": 5,
      "verseNumber": 4,
      "spanishTranslation": "Mi amado metió su mano por la ventanilla,Y mi corazón se conmovió dentro de mí.",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "SON_5_5",
      "bookId": "SON",
      "bookName": "Cantares",
      "chapter": 5,
      "verseNumber": 5,
      "spanishTranslation": "Yo me levanté para abrir a mi amado,Y mis manos gotearon mirra,Y mis dedos mirra, que corríaSobre la manecilla del cerrojo.",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "SON_5_6",
      "bookId": "SON",
      "bookName": "Cantares",
      "chapter": 5,
      "verseNumber": 6,
      "spanishTranslation": "Abrí yo a mi amado;Pero mi amado se había ido, había ya pasado;Y tras su hablar salió mi alma.Lo busqué, y no lo hallé;Lo llamé, y no me respondió.",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "SON_5_7",
      "bookId": "SON",
      "bookName": "Cantares",
      "chapter": 5,
      "verseNumber": 7,
      "spanishTranslation": "Me hallaron los guardas que rondan la ciudad;Me golpearon, me hirieron;Me quitaron mi manto de encima los guardas de los muros.",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "SON_5_8",
      "bookId": "SON",
      "bookName": "Cantares",
      "chapter": 5,
      "verseNumber": 8,
      "spanishTranslation": "Yo os conjuro, oh doncellas de Jerusalén, si halláis a mi amado,Que le hagáis saber que estoy enferma de amor.",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "SON_5_9",
      "bookId": "SON",
      "bookName": "Cantares",
      "chapter": 5,
      "verseNumber": 9,
      "spanishTranslation": "¿Qué es tu amado más que otro amado,Oh la más hermosa de todas las mujeres?¿Qué es tu amado más que otro amado,Que así nos conjuras?",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "SON_5_10",
      "bookId": "SON",
      "bookName": "Cantares",
      "chapter": 5,
      "verseNumber": 10,
      "spanishTranslation": "Mi amado es blanco y rubio,Señalado entre diez mil.",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "SON_5_11",
      "bookId": "SON",
      "bookName": "Cantares",
      "chapter": 5,
      "verseNumber": 11,
      "spanishTranslation": "Su cabeza como oro finísimo;Sus cabellos crespos, negros como el cuervo.",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "SON_5_12",
      "bookId": "SON",
      "bookName": "Cantares",
      "chapter": 5,
      "verseNumber": 12,
      "spanishTranslation": "Sus ojos, como palomas junto a los arroyos de las aguas,Que se lavan con leche, y a la perfección colocados.",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "SON_5_13",
      "bookId": "SON",
      "bookName": "Cantares",
      "chapter": 5,
      "verseNumber": 13,
      "spanishTranslation": "Sus mejillas, como una era de especias aromáticas, como fragantes flores;Sus labios, como lirios que destilan mirra fragante.",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "SON_5_14",
      "bookId": "SON",
      "bookName": "Cantares",
      "chapter": 5,
      "verseNumber": 14,
      "spanishTranslation": "Sus manos, como anillos de oro engastados de jacintos;Su cuerpo, como claro marfil cubierto de zafiros.",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "SON_5_15",
      "bookId": "SON",
      "bookName": "Cantares",
      "chapter": 5,
      "verseNumber": 15,
      "spanishTranslation": "Sus piernas, como columnas de mármol fundadas sobre basas de oro fino;Su aspecto como el Líbano, escogido como los cedros.",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "SON_5_16",
      "bookId": "SON",
      "bookName": "Cantares",
      "chapter": 5,
      "verseNumber": 16,
      "spanishTranslation": "Su paladar, dulcísimo, y todo él codiciable.Tal es mi amado, tal es mi amigo,Oh doncellas de Jerusalén.",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "SON_6_1",
      "bookId": "SON",
      "bookName": "Cantares",
      "chapter": 6,
      "verseNumber": 1,
      "spanishTranslation": "¿A dónde se ha ido tu amado, oh la más hermosa de todas las mujeres?¿A dónde se apartó tu amado,Y lo buscaremos contigo?",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "SON_6_2",
      "bookId": "SON",
      "bookName": "Cantares",
      "chapter": 6,
      "verseNumber": 2,
      "spanishTranslation": "Mi amado descendió a su huerto, a las eras de las especias,Para apacentar en los huertos, y para recoger los lirios.",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "SON_6_3",
      "bookId": "SON",
      "bookName": "Cantares",
      "chapter": 6,
      "verseNumber": 3,
      "spanishTranslation": "Yo soy de mi amado, y mi amado es mío;Él apacienta entre los lirios.",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "SON_6_4",
      "bookId": "SON",
      "bookName": "Cantares",
      "chapter": 6,
      "verseNumber": 4,
      "spanishTranslation": "Hermosa eres tú, oh amiga mía, como Tirsa;De desear, como Jerusalén;Imponente como ejércitos en orden.",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "SON_6_5",
      "bookId": "SON",
      "bookName": "Cantares",
      "chapter": 6,
      "verseNumber": 5,
      "spanishTranslation": "Aparta tus ojos de delante de mí,Porque ellos me vencieron.Tu cabello es como manada de cabrasQue se recuestan en las laderas de Galaad.",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "SON_6_6",
      "bookId": "SON",
      "bookName": "Cantares",
      "chapter": 6,
      "verseNumber": 6,
      "spanishTranslation": "Tus dientes, como manadas de ovejas que suben del lavadero,Todas con crías gemelas,Y estéril no hay entre ellas.",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "SON_6_7",
      "bookId": "SON",
      "bookName": "Cantares",
      "chapter": 6,
      "verseNumber": 7,
      "spanishTranslation": "Como cachos de granada son tus mejillasDetrás de tu velo.",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "SON_6_8",
      "bookId": "SON",
      "bookName": "Cantares",
      "chapter": 6,
      "verseNumber": 8,
      "spanishTranslation": "Sesenta son las reinas, y ochenta las concubinas,Y las doncellas sin número;",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "SON_6_9",
      "bookId": "SON",
      "bookName": "Cantares",
      "chapter": 6,
      "verseNumber": 9,
      "spanishTranslation": "Mas una es la paloma mía, la perfecta mía;Es la única de su madre,La escogida de la que la dio a luz.La vieron las doncellas, y la llamaron bienaventurada;Las reinas y las concubinas, y la alabaron.",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "SON_6_10",
      "bookId": "SON",
      "bookName": "Cantares",
      "chapter": 6,
      "verseNumber": 10,
      "spanishTranslation": "¿Quién es ésta que se muestra como el alba,Hermosa como la luna,Esclarecida como el sol,Imponente como ejércitos en orden?",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "SON_6_11",
      "bookId": "SON",
      "bookName": "Cantares",
      "chapter": 6,
      "verseNumber": 11,
      "spanishTranslation": "Al huerto de los nogales descendíA ver los frutos del valle,Y para ver si brotaban las vides,Si florecían los granados.",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "SON_6_12",
      "bookId": "SON",
      "bookName": "Cantares",
      "chapter": 6,
      "verseNumber": 12,
      "spanishTranslation": "Antes que lo supiera, mi alma me pusoEntre los carros de Aminadab.",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "SON_6_13",
      "bookId": "SON",
      "bookName": "Cantares",
      "chapter": 6,
      "verseNumber": 13,
      "spanishTranslation": "Vuélvete, vuélvete, oh sulamita;Vuélvete, vuélvete, y te miraremos.¿Qué veréis en la sulamita?Algo como la reunión de dos campamentos.",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "SON_7_1",
      "bookId": "SON",
      "bookName": "Cantares",
      "chapter": 7,
      "verseNumber": 1,
      "spanishTranslation": "¡Cuán hermosos son tus pies en las sandalias,Oh hija de príncipe!Los contornos de tus muslos son como joyas,Obra de mano de excelente maestro.",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "SON_7_2",
      "bookId": "SON",
      "bookName": "Cantares",
      "chapter": 7,
      "verseNumber": 2,
      "spanishTranslation": "Tu ombligo como una taza redondaQue no le falta bebida.Tu vientre como montón de trigoCercado de lirios.",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "SON_7_3",
      "bookId": "SON",
      "bookName": "Cantares",
      "chapter": 7,
      "verseNumber": 3,
      "spanishTranslation": "Tus dos pechos, como gemelos de gacela.",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "SON_7_4",
      "bookId": "SON",
      "bookName": "Cantares",
      "chapter": 7,
      "verseNumber": 4,
      "spanishTranslation": "Tu cuello, como torre de marfil;Tus ojos, como los estanques de Hesbón junto a la puerta de Bat-rabim;Tu nariz, como la torre del Líbano,Que mira hacia Damasco.",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "SON_7_5",
      "bookId": "SON",
      "bookName": "Cantares",
      "chapter": 7,
      "verseNumber": 5,
      "spanishTranslation": "Tu cabeza encima de ti, como el Carmelo;Y el cabello de tu cabeza, como la púrpura del reySuspendida en los corredores.",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "SON_7_6",
      "bookId": "SON",
      "bookName": "Cantares",
      "chapter": 7,
      "verseNumber": 6,
      "spanishTranslation": "¡Qué hermosa eres, y cuán suave,Oh amor deleitoso!",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "SON_7_7",
      "bookId": "SON",
      "bookName": "Cantares",
      "chapter": 7,
      "verseNumber": 7,
      "spanishTranslation": "Tu estatura es semejante a la palmera,Y tus pechos a los racimos.",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "SON_7_8",
      "bookId": "SON",
      "bookName": "Cantares",
      "chapter": 7,
      "verseNumber": 8,
      "spanishTranslation": "Yo dije: Subiré a la palmera,Asiré sus ramas.Deja que tus pechos sean como racimos de vid,Y el olor de tu boca como de manzanas,",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "SON_7_9",
      "bookId": "SON",
      "bookName": "Cantares",
      "chapter": 7,
      "verseNumber": 9,
      "spanishTranslation": "Y tu paladar como el buen vino,Que se entra a mi amado suavemente,Y hace hablar los labios de los viejos.",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "SON_7_10",
      "bookId": "SON",
      "bookName": "Cantares",
      "chapter": 7,
      "verseNumber": 10,
      "spanishTranslation": "Yo soy de mi amado,Y conmigo tiene su contentamiento.",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "SON_7_11",
      "bookId": "SON",
      "bookName": "Cantares",
      "chapter": 7,
      "verseNumber": 11,
      "spanishTranslation": "Ven, oh amado mío, salgamos al campo,Moremos en las aldeas.",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "SON_7_12",
      "bookId": "SON",
      "bookName": "Cantares",
      "chapter": 7,
      "verseNumber": 12,
      "spanishTranslation": "Levantémonos de mañana a las viñas;Veamos si brotan las vides, si están en cierne,Si han florecido los granados;Allí te daré mis amores.",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "SON_7_13",
      "bookId": "SON",
      "bookName": "Cantares",
      "chapter": 7,
      "verseNumber": 13,
      "spanishTranslation": "Las mandrágoras han dado olor,Y a nuestras puertas hay toda suerte de dulces frutas,Nuevas y añejas, que para ti, oh amado mío, he guardado.",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "SON_8_1",
      "bookId": "SON",
      "bookName": "Cantares",
      "chapter": 8,
      "verseNumber": 1,
      "spanishTranslation": "¡Oh, si tú fueras como un hermano míoQue mamó los pechos de mi madre!Entonces, hallándote fuera, te besaría,Y no me menospreciarían.",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "SON_8_2",
      "bookId": "SON",
      "bookName": "Cantares",
      "chapter": 8,
      "verseNumber": 2,
      "spanishTranslation": "Yo te llevaría, te metería en casa de mi madre;Tú me enseñarías,Y yo te haría beber vinoAdobado del mosto de mis granadas.",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "SON_8_3",
      "bookId": "SON",
      "bookName": "Cantares",
      "chapter": 8,
      "verseNumber": 3,
      "spanishTranslation": "Su izquierda esté debajo de mi cabeza,Y su derecha me abrace.",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "SON_8_4",
      "bookId": "SON",
      "bookName": "Cantares",
      "chapter": 8,
      "verseNumber": 4,
      "spanishTranslation": "Os conjuro, oh doncellas de Jerusalén,Que no despertéis ni hagáis velar al amor,Hasta que quiera.",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "SON_8_5",
      "bookId": "SON",
      "bookName": "Cantares",
      "chapter": 8,
      "verseNumber": 5,
      "spanishTranslation": "¿Quién es ésta que sube del desierto,Recostada sobre su amado?Debajo de un manzano te desperté;Allí tuvo tu madre dolores,Allí tuvo dolores la que te dio a luz.",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "SON_8_6",
      "bookId": "SON",
      "bookName": "Cantares",
      "chapter": 8,
      "verseNumber": 6,
      "spanishTranslation": "Ponme como un sello sobre tu corazón, como una marca sobre tu brazo;Porque fuerte es como la muerte el amor;Duros como el Seol los celos;Sus brasas, brasas de fuego, fuerte llama.",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "SON_8_7",
      "bookId": "SON",
      "bookName": "Cantares",
      "chapter": 8,
      "verseNumber": 7,
      "spanishTranslation": "Las muchas aguas no podrán apagar el amor,Ni lo ahogarán los ríos.Si diese el hombre todos los bienes de su casa por este amor,De cierto lo menospreciarían.",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "SON_8_8",
      "bookId": "SON",
      "bookName": "Cantares",
      "chapter": 8,
      "verseNumber": 8,
      "spanishTranslation": "Tenemos una pequeña hermana,Que no tiene pechos;¿Qué haremos a nuestra hermanaCuando de ella se hablare?",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "SON_8_9",
      "bookId": "SON",
      "bookName": "Cantares",
      "chapter": 8,
      "verseNumber": 9,
      "spanishTranslation": "Si ella es muro,Edificaremos sobre él un palacio de plata;Si fuere puerta,La guarneceremos con tablas de cedro.",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "SON_8_10",
      "bookId": "SON",
      "bookName": "Cantares",
      "chapter": 8,
      "verseNumber": 10,
      "spanishTranslation": "Yo soy muro, y mis pechos como torres,Desde que fui en sus ojos como la que halla paz.",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "SON_8_11",
      "bookId": "SON",
      "bookName": "Cantares",
      "chapter": 8,
      "verseNumber": 11,
      "spanishTranslation": "Salomón tuvo una viña en Baal-hamón,La cual entregó a guardas,Cada uno de los cuales debía traer mil monedas de plata por su fruto.",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "SON_8_12",
      "bookId": "SON",
      "bookName": "Cantares",
      "chapter": 8,
      "verseNumber": 12,
      "spanishTranslation": "Mi viña, que es mía, está delante de mí;Las mil serán tuyas, oh Salomón,Y doscientas para los que guardan su fruto.",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
