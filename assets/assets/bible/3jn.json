{
  "bookId": "3JN",
  "verses": [
    {
      "id": "3JN_1_1",
      "bookId": "3JN",
      "bookName": "3 Juan",
      "chapter": 1,
      "verseNumber": 1,
      "spanishTranslation": "El anciano a Gayo, el amado, a quien amo en la verdad.",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "3JN_1_2",
      "bookId": "3JN",
      "bookName": "3 Juan",
      "chapter": 1,
      "verseNumber": 2,
      "spanishTranslation": "Amado, yo deseo que tú seas prosperado en todas las cosas, y que tengas salud, así como prospera tu alma.",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "3JN_1_3",
      "bookId": "3JN",
      "bookName": "3 Juan",
      "chapter": 1,
      "verseNumber": 3,
      "spanishTranslation": "Pues mucho me regocijé cuando vinieron los hermanos y dieron testimonio de tu verdad, de cómo andas en la verdad.",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "3JN_1_4",
      "bookId": "3JN",
      "bookName": "3 Juan",
      "chapter": 1,
      "verseNumber": 4,
      "spanishTranslation": "No tengo yo mayor gozo que éste, el oír que mis hijos andan en la verdad.",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "3JN_1_5",
      "bookId": "3JN",
      "bookName": "3 Juan",
      "chapter": 1,
      "verseNumber": 5,
      "spanishTranslation": "Amado, fielmente te conduces cuando prestas algún servicio a los hermanos, especialmente a los desconocidos,",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "3JN_1_6",
      "bookId": "3JN",
      "bookName": "3 Juan",
      "chapter": 1,
      "verseNumber": 6,
      "spanishTranslation": "los cuales han dado ante la iglesia testimonio de tu amor; y harás bien en encaminarlos como es digno de su servicio a Dios, para que continúen su viaje.",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "3JN_1_7",
      "bookId": "3JN",
      "bookName": "3 Juan",
      "chapter": 1,
      "verseNumber": 7,
      "spanishTranslation": "Porque ellos salieron por amor del nombre de él, sin aceptar nada de los gentiles.",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "3JN_1_8",
      "bookId": "3JN",
      "bookName": "3 Juan",
      "chapter": 1,
      "verseNumber": 8,
      "spanishTranslation": "Nosotros, pues, debemos acoger a tales personas, para que cooperemos con la verdad.",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "3JN_1_9",
      "bookId": "3JN",
      "bookName": "3 Juan",
      "chapter": 1,
      "verseNumber": 9,
      "spanishTranslation": "Yo he escrito a la iglesia; pero Diótrefes, al cual le gusta tener el primer lugar entre ellos, no nos recibe.",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "3JN_1_10",
      "bookId": "3JN",
      "bookName": "3 Juan",
      "chapter": 1,
      "verseNumber": 10,
      "spanishTranslation": "Por esta causa, si yo fuere, recordaré las obras que hace parloteando con palabras malignas contra nosotros; y no contento con estas cosas, no recibe a los hermanos, y a los que quieren recibirlos se lo prohíbe, y los expulsa de la iglesia.",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "3JN_1_11",
      "bookId": "3JN",
      "bookName": "3 Juan",
      "chapter": 1,
      "verseNumber": 11,
      "spanishTranslation": "Amado, no imites lo malo, sino lo bueno. El que hace lo bueno es de Dios; pero el que hace lo malo, no ha visto a Dios.",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "3JN_1_12",
      "bookId": "3JN",
      "bookName": "3 Juan",
      "chapter": 1,
      "verseNumber": 12,
      "spanishTranslation": "Todos dan testimonio de Demetrio, y aun la verdad misma; y también nosotros damos testimonio, y vosotros sabéis que nuestro testimonio es verdadero.",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "3JN_1_13",
      "bookId": "3JN",
      "bookName": "3 Juan",
      "chapter": 1,
      "verseNumber": 13,
      "spanishTranslation": "Yo tenía muchas cosas que escribirte, pero no quiero escribírtelas con tinta y pluma,",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "3JN_1_14",
      "bookId": "3JN",
      "bookName": "3 Juan",
      "chapter": 1,
      "verseNumber": 14,
      "spanishTranslation": "porque espero verte en breve, y hablaremos cara a cara.",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "3JN_1_15",
      "bookId": "3JN",
      "bookName": "3 Juan",
      "chapter": 1,
      "verseNumber": 15,
      "spanishTranslation": "La paz sea contigo. Los amigos te saludan. Saluda tú a los amigos, a cada uno en particular.",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    }
  ]
}