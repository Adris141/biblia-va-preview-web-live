{
  "bookId": "PHP",
  "verses": [
    {
      "id": "PHP_1_1",
      "bookId": "PHP",
      "bookName": "Filipenses",
      "chapter": 1,
      "verseNumber": 1,
      "spanishTranslation": "Pablo y Timoteo, siervos de Jesucristo, a todos los santos en Cristo Jesús que están en Filipos, con los obispos y diáconos:",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "PHP_1_2",
      "bookId": "PHP",
      "bookName": "Filipenses",
      "chapter": 1,
      "verseNumber": 2,
      "spanishTranslation": "Gracia y paz a vosotros, de Dios nuestro Padre y del Señor Jesucristo.",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "PHP_1_3",
      "bookId": "PHP",
      "bookName": "Filipenses",
      "chapter": 1,
      "verseNumber": 3,
      "spanishTranslation": "Doy gracias a mi Dios siempre que me acuerdo de vosotros,",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "PHP_1_4",
      "bookId": "PHP",
      "bookName": "Filipenses",
      "chapter": 1,
      "verseNumber": 4,
      "spanishTranslation": "siempre en todas mis oraciones rogando con gozo por todos vosotros,",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "PHP_1_5",
      "bookId": "PHP",
      "bookName": "Filipenses",
      "chapter": 1,
      "verseNumber": 5,
      "spanishTranslation": "por vuestra comunión en el evangelio, desde el primer día hasta ahora;",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "PHP_1_6",
      "bookId": "PHP",
      "bookName": "Filipenses",
      "chapter": 1,
      "verseNumber": 6,
      "spanishTranslation": "estando persuadido de esto, que el que comenzó en vosotros la buena obra, la perfeccionará hasta el día de Jesucristo;",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "PHP_1_7",
      "bookId": "PHP",
      "bookName": "Filipenses",
      "chapter": 1,
      "verseNumber": 7,
      "spanishTranslation": "como me es justo sentir esto de todos vosotros, por cuanto os tengo en el corazón; y en mis prisiones, y en la defensa y confirmación del evangelio, todos vosotros sois participantes conmigo de la gracia.",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "PHP_1_8",
      "bookId": "PHP",
      "bookName": "Filipenses",
      "chapter": 1,
      "verseNumber": 8,
      "spanishTranslation": "Porque Dios me es testigo de cómo os amo a todos vosotros con el entrañable amor de Jesucristo.",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "PHP_1_9",
      "bookId": "PHP",
      "bookName": "Filipenses",
      "chapter": 1,
      "verseNumber": 9,
      "spanishTranslation": "Y esto pido en oración, que vuestro amor abunde aún más y más en ciencia y en todo conocimiento,",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "PHP_1_10",
      "bookId": "PHP",
      "bookName": "Filipenses",
      "chapter": 1,
      "verseNumber": 10,
      "spanishTranslation": "para que aprobéis lo mejor, a fin de que seáis sinceros e irreprensibles para el día de Cristo,",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "PHP_1_11",
      "bookId": "PHP",
      "bookName": "Filipenses",
      "chapter": 1,
      "verseNumber": 11,
      "spanishTranslation": "llenos de frutos de justicia que son por medio de Jesucristo, para gloria y alabanza de Dios.",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "PHP_1_12",
      "bookId": "PHP",
      "bookName": "Filipenses",
      "chapter": 1,
      "verseNumber": 12,
      "spanishTranslation": "Quiero que sepáis, hermanos, que las cosas que me han sucedido, han redundado más bien para el progreso del evangelio,",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "PHP_1_13",
      "bookId": "PHP",
      "bookName": "Filipenses",
      "chapter": 1,
      "verseNumber": 13,
      "spanishTranslation": "de tal manera que mis prisiones se han hecho patentes en Cristo en todo el pretorio, y a todos los demás.",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "PHP_1_14",
      "bookId": "PHP",
      "bookName": "Filipenses",
      "chapter": 1,
      "verseNumber": 14,
      "spanishTranslation": "Y la mayoría de los hermanos, cobrando ánimo en el Señor con mis prisiones, se atreven mucho más a hablar la palabra sin temor.",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "PHP_1_15",
      "bookId": "PHP",
      "bookName": "Filipenses",
      "chapter": 1,
      "verseNumber": 15,
      "spanishTranslation": "Algunos, a la verdad, predican a Cristo por envidia y contienda; pero otros de buena voluntad.",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "PHP_1_16",
      "bookId": "PHP",
      "bookName": "Filipenses",
      "chapter": 1,
      "verseNumber": 16,
      "spanishTranslation": "Los unos anuncian a Cristo por contención, no sinceramente, pensando añadir aflicción a mis prisiones;",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "PHP_1_17",
      "bookId": "PHP",
      "bookName": "Filipenses",
      "chapter": 1,
      "verseNumber": 17,
      "spanishTranslation": "pero los otros por amor, sabiendo que estoy puesto para la defensa del evangelio.",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "PHP_1_18",
      "bookId": "PHP",
      "bookName": "Filipenses",
      "chapter": 1,
      "verseNumber": 18,
      "spanishTranslation": "¿Qué, pues? Que no obstante, de todas maneras, o por pretexto o por verdad, Cristo es anunciado; y en esto me gozo, y me gozaré aún.",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "PHP_1_19",
      "bookId": "PHP",
      "bookName": "Filipenses",
      "chapter": 1,
      "verseNumber": 19,
      "spanishTranslation": "Porque sé que por vuestra oración y la suministración del Espíritu de Jesucristo, esto resultará en mi liberación,",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "PHP_1_20",
      "bookId": "PHP",
      "bookName": "Filipenses",
      "chapter": 1,
      "verseNumber": 20,
      "spanishTranslation": "conforme a mi anhelo y esperanza de que en nada seré avergonzado; antes bien con toda confianza, como siempre, ahora también será magnificado Cristo en mi cuerpo, o por vida o por muerte.",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "PHP_1_21",
      "bookId": "PHP",
      "bookName": "Filipenses",
      "chapter": 1,
      "verseNumber": 21,
      "spanishTranslation": "Porque para mí el vivir es Cristo, y el morir es ganancia.",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "PHP_1_22",
      "bookId": "PHP",
      "bookName": "Filipenses",
      "chapter": 1,
      "verseNumber": 22,
      "spanishTranslation": "Mas si el vivir en la carne resulta para mí en beneficio de la obra, no sé entonces qué escoger.",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "PHP_1_23",
      "bookId": "PHP",
      "bookName": "Filipenses",
      "chapter": 1,
      "verseNumber": 23,
      "spanishTranslation": "Porque de ambas cosas estoy puesto en estrecho, teniendo deseo de partir y estar con Cristo, lo cual es muchísimo mejor;",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "PHP_1_24",
      "bookId": "PHP",
      "bookName": "Filipenses",
      "chapter": 1,
      "verseNumber": 24,
      "spanishTranslation": "pero quedar en la carne es más necesario por causa de vosotros.",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "PHP_1_25",
      "bookId": "PHP",
      "bookName": "Filipenses",
      "chapter": 1,
      "verseNumber": 25,
      "spanishTranslation": "Y confiado en esto, sé que quedaré, que aún permaneceré con todos vosotros, para vuestro provecho y gozo de la fe,",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "PHP_1_26",
      "bookId": "PHP",
      "bookName": "Filipenses",
      "chapter": 1,
      "verseNumber": 26,
      "spanishTranslation": "para que abunde vuestra gloria de mí en Cristo Jesús por mi presencia otra vez entre vosotros.",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "PHP_1_27",
      "bookId": "PHP",
      "bookName": "Filipenses",
      "chapter": 1,
      "verseNumber": 27,
      "spanishTranslation": "Solamente que os comportéis como es digno del evangelio de Cristo, para que o sea que vaya a veros, o que esté ausente, oiga de vosotros que estáis firmes en un mismo espíritu, combatiendo unánimes por la fe del evangelio,",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "PHP_1_28",
      "bookId": "PHP",
      "bookName": "Filipenses",
      "chapter": 1,
      "verseNumber": 28,
      "spanishTranslation": "y en nada intimidados por los que se oponen, que para ellos ciertamente es indicio de perdición, mas para vosotros de salvación; y esto de Dios.",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "PHP_1_29",
      "bookId": "PHP",
      "bookName": "Filipenses",
      "chapter": 1,
      "verseNumber": 29,
      "spanishTranslation": "Porque a vosotros os es concedido a causa de Cristo, no sólo que creáis en él, sino también que padezcáis por él,",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "PHP_1_30",
      "bookId": "PHP",
      "bookName": "Filipenses",
      "chapter": 1,
      "verseNumber": 30,
      "spanishTranslation": "teniendo el mismo conflicto que habéis visto en mí, y ahora oís que hay en mí.",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "PHP_2_1",
      "bookId": "PHP",
      "bookName": "Filipenses",
      "chapter": 2,
      "verseNumber": 1,
      "spanishTranslation": "Por tanto, si hay alguna consolación en Cristo, si algún consuelo de amor, si alguna comunión del Espíritu, si algún afecto entrañable, si alguna misericordia,",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "PHP_2_2",
      "bookId": "PHP",
      "bookName": "Filipenses",
      "chapter": 2,
      "verseNumber": 2,
      "spanishTranslation": "completad mi gozo, sintiendo lo mismo, teniendo el mismo amor, unánimes, sintiendo una misma cosa.",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "PHP_2_3",
      "bookId": "PHP",
      "bookName": "Filipenses",
      "chapter": 2,
      "verseNumber": 3,
      "spanishTranslation": "Nada hagáis por contienda o por vanagloria; antes bien con humildad, estimando cada uno a los demás como superiores a él mismo;",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "PHP_2_4",
      "bookId": "PHP",
      "bookName": "Filipenses",
      "chapter": 2,
      "verseNumber": 4,
      "spanishTranslation": "no mirando cada uno por lo suyo propio, sino cada cual también por lo de los otros.",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "PHP_2_5",
      "bookId": "PHP",
      "bookName": "Filipenses",
      "chapter": 2,
      "verseNumber": 5,
      "spanishTranslation": "Haya, pues, en vosotros este sentir que hubo también en Cristo Jesús,",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "PHP_2_6",
      "bookId": "PHP",
      "bookName": "Filipenses",
      "chapter": 2,
      "verseNumber": 6,
      "spanishTranslation": "el cual, siendo en forma de Dios, no estimó el ser igual a Dios como cosa a que aferrarse,",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "PHP_2_7",
      "bookId": "PHP",
      "bookName": "Filipenses",
      "chapter": 2,
      "verseNumber": 7,
      "spanishTranslation": "sino que se despojó a sí mismo, tomando forma de siervo, hecho semejante a los hombres;",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "PHP_2_8",
      "bookId": "PHP",
      "bookName": "Filipenses",
      "chapter": 2,
      "verseNumber": 8,
      "spanishTranslation": "y estando en la condición de hombre, se humilló a sí mismo, haciéndose obediente hasta la muerte, y muerte de cruz.",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "PHP_2_9",
      "bookId": "PHP",
      "bookName": "Filipenses",
      "chapter": 2,
      "verseNumber": 9,
      "spanishTranslation": "Por lo cual Dios también le exaltó hasta lo sumo, y le dio un nombre que es sobre todo nombre,",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "PHP_2_10",
      "bookId": "PHP",
      "bookName": "Filipenses",
      "chapter": 2,
      "verseNumber": 10,
      "spanishTranslation": "para que en el nombre de Jesús se doble toda rodilla de los que están en los cielos, y en la tierra, y debajo de la tierra;",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "PHP_2_11",
      "bookId": "PHP",
      "bookName": "Filipenses",
      "chapter": 2,
      "verseNumber": 11,
      "spanishTranslation": "y toda lengua confiese que Jesucristo es el Señor, para gloria de Dios Padre.",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "PHP_2_12",
      "bookId": "PHP",
      "bookName": "Filipenses",
      "chapter": 2,
      "verseNumber": 12,
      "spanishTranslation": "Por tanto, amados míos, como siempre habéis obedecido, no como en mi presencia solamente, sino mucho más ahora en mi ausencia, ocupaos en vuestra salvación con temor y temblor,",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "PHP_2_13",
      "bookId": "PHP",
      "bookName": "Filipenses",
      "chapter": 2,
      "verseNumber": 13,
      "spanishTranslation": "porque Dios es el que en vosotros produce así el querer como el hacer, por su buena voluntad.",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "PHP_2_14",
      "bookId": "PHP",
      "bookName": "Filipenses",
      "chapter": 2,
      "verseNumber": 14,
      "spanishTranslation": "Haced todo sin murmuraciones y contiendas,",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "PHP_2_15",
      "bookId": "PHP",
      "bookName": "Filipenses",
      "chapter": 2,
      "verseNumber": 15,
      "spanishTranslation": "para que seáis irreprensibles y sencillos, hijos de Dios sin mancha en medio de una generación maligna y perversa, en medio de la cual resplandecéis como luminares en el mundo;",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "PHP_2_16",
      "bookId": "PHP",
      "bookName": "Filipenses",
      "chapter": 2,
      "verseNumber": 16,
      "spanishTranslation": "asidos de la palabra de vida, para que en el día de Cristo yo pueda gloriarme de que no he corrido en vano, ni en vano he trabajado.",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "PHP_2_17",
      "bookId": "PHP",
      "bookName": "Filipenses",
      "chapter": 2,
      "verseNumber": 17,
      "spanishTranslation": "Y aunque sea derramado en libación sobre el sacrificio y servicio de vuestra fe, me gozo y regocijo con todos vosotros.",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "PHP_2_18",
      "bookId": "PHP",
      "bookName": "Filipenses",
      "chapter": 2,
      "verseNumber": 18,
      "spanishTranslation": "Y asimismo gozaos y regocijaos también vosotros conmigo.",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "PHP_2_19",
      "bookId": "PHP",
      "bookName": "Filipenses",
      "chapter": 2,
      "verseNumber": 19,
      "spanishTranslation": "Espero en el Señor Jesús enviaros pronto a Timoteo, para que yo también esté de buen ánimo al saber de vuestro estado;",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "PHP_2_20",
      "bookId": "PHP",
      "bookName": "Filipenses",
      "chapter": 2,
      "verseNumber": 20,
      "spanishTranslation": "pues a ninguno tengo del mismo ánimo, y que tan sinceramente se interese por vosotros.",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "PHP_2_21",
      "bookId": "PHP",
      "bookName": "Filipenses",
      "chapter": 2,
      "verseNumber": 21,
      "spanishTranslation": "Porque todos buscan lo suyo propio, no lo que es de Cristo Jesús.",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "PHP_2_22",
      "bookId": "PHP",
      "bookName": "Filipenses",
      "chapter": 2,
      "verseNumber": 22,
      "spanishTranslation": "Pero ya conocéis los méritos de él, que como hijo a padre ha servido conmigo en el evangelio.",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "PHP_2_23",
      "bookId": "PHP",
      "bookName": "Filipenses",
      "chapter": 2,
      "verseNumber": 23,
      "spanishTranslation": "Así que a éste espero enviaros, luego que yo vea cómo van mis asuntos;",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "PHP_2_24",
      "bookId": "PHP",
      "bookName": "Filipenses",
      "chapter": 2,
      "verseNumber": 24,
      "spanishTranslation": "y confío en el Señor que yo también iré pronto a vosotros.",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "PHP_2_25",
      "bookId": "PHP",
      "bookName": "Filipenses",
      "chapter": 2,
      "verseNumber": 25,
      "spanishTranslation": "Mas tuve por necesario enviaros a Epafrodito, mi hermano y colaborador y compañero de milicia, vuestro mensajero, y ministrador de mis necesidades;",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "PHP_2_26",
      "bookId": "PHP",
      "bookName": "Filipenses",
      "chapter": 2,
      "verseNumber": 26,
      "spanishTranslation": "porque él tenía gran deseo de veros a todos vosotros, y gravemente se angustió porque habíais oído que había enfermado.",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "PHP_2_27",
      "bookId": "PHP",
      "bookName": "Filipenses",
      "chapter": 2,
      "verseNumber": 27,
      "spanishTranslation": "Pues en verdad estuvo enfermo, a punto de morir; pero Dios tuvo misericordia de él, y no solamente de él, sino también de mí, para que yo no tuviese tristeza sobre tristeza.",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "PHP_2_28",
      "bookId": "PHP",
      "bookName": "Filipenses",
      "chapter": 2,
      "verseNumber": 28,
      "spanishTranslation": "Así que le envío con mayor solicitud, para que al verle de nuevo, os gocéis, y yo esté con menos tristeza.",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "PHP_2_29",
      "bookId": "PHP",
      "bookName": "Filipenses",
      "chapter": 2,
      "verseNumber": 29,
      "spanishTranslation": "Recibidle, pues, en el Señor, con todo gozo, y tened en estima a los que son como él;",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "PHP_2_30",
      "bookId": "PHP",
      "bookName": "Filipenses",
      "chapter": 2,
      "verseNumber": 30,
      "spanishTranslation": "porque por la obra de Cristo estuvo próximo a la muerte, exponiendo su vida para suplir lo que faltaba en vuestro servicio por mí.",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "PHP_3_1",
      "bookId": "PHP",
      "bookName": "Filipenses",
      "chapter": 3,
      "verseNumber": 1,
      "spanishTranslation": "Por lo demás, hermanos, gozaos en el Señor. A mí no me es molesto el escribiros las mismas cosas, y para vosotros es seguro.",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "PHP_3_2",
      "bookId": "PHP",
      "bookName": "Filipenses",
      "chapter": 3,
      "verseNumber": 2,
      "spanishTranslation": "Guardaos de los perros, guardaos de los malos obreros, guardaos de los mutiladores del cuerpo.",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "PHP_3_3",
      "bookId": "PHP",
      "bookName": "Filipenses",
      "chapter": 3,
      "verseNumber": 3,
      "spanishTranslation": "Porque nosotros somos la circuncisión, los que en espíritu servimos a Dios y nos gloriamos en Cristo Jesús, no teniendo confianza en la carne.",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "PHP_3_4",
      "bookId": "PHP",
      "bookName": "Filipenses",
      "chapter": 3,
      "verseNumber": 4,
      "spanishTranslation": "Aunque yo tengo también de qué confiar en la carne. Si alguno piensa que tiene de qué confiar en la carne, yo más:",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "PHP_3_5",
      "bookId": "PHP",
      "bookName": "Filipenses",
      "chapter": 3,
      "verseNumber": 5,
      "spanishTranslation": "circuncidado al octavo día, del linaje de Israel, de la tribu de Benjamín, hebreo de hebreos; en cuanto a la ley, fariseo;",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "PHP_3_6",
      "bookId": "PHP",
      "bookName": "Filipenses",
      "chapter": 3,
      "verseNumber": 6,
      "spanishTranslation": "en cuanto a celo, perseguidor de la iglesia; en cuanto a la justicia que es en la ley, irreprensible.",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "PHP_3_7",
      "bookId": "PHP",
      "bookName": "Filipenses",
      "chapter": 3,
      "verseNumber": 7,
      "spanishTranslation": "Pero cuantas cosas eran para mí ganancia, las he estimado como pérdida por amor de Cristo.",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "PHP_3_8",
      "bookId": "PHP",
      "bookName": "Filipenses",
      "chapter": 3,
      "verseNumber": 8,
      "spanishTranslation": "Y ciertamente, aun estimo todas las cosas como pérdida por la excelencia del conocimiento de Cristo Jesús, mi Señor, por amor del cual lo he perdido todo, y lo tengo por basura, para ganar a Cristo,",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "PHP_3_9",
      "bookId": "PHP",
      "bookName": "Filipenses",
      "chapter": 3,
      "verseNumber": 9,
      "spanishTranslation": "y ser hallado en él, no teniendo mi propia justicia, que es por la ley, sino la que es por la fe de Cristo, la justicia que es de Dios por la fe;",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "PHP_3_10",
      "bookId": "PHP",
      "bookName": "Filipenses",
      "chapter": 3,
      "verseNumber": 10,
      "spanishTranslation": "a fin de conocerle, y el poder de su resurrección, y la participación de sus padecimientos, llegando a ser semejante a él en su muerte,",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "PHP_3_11",
      "bookId": "PHP",
      "bookName": "Filipenses",
      "chapter": 3,
      "verseNumber": 11,
      "spanishTranslation": "si en alguna manera llegase a la resurrección de entre los muertos.",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "PHP_3_12",
      "bookId": "PHP",
      "bookName": "Filipenses",
      "chapter": 3,
      "verseNumber": 12,
      "spanishTranslation": "No que lo haya alcanzado ya, ni que ya sea perfecto; sino que prosigo, por ver si logro asir aquello para lo cual fui también asido por Cristo Jesús.",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "PHP_3_13",
      "bookId": "PHP",
      "bookName": "Filipenses",
      "chapter": 3,
      "verseNumber": 13,
      "spanishTranslation": "Hermanos, yo mismo no pretendo haberlo ya alcanzado; pero una cosa hago: olvidando ciertamente lo que queda atrás, y extendiéndome a lo que está delante,",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "PHP_3_14",
      "bookId": "PHP",
      "bookName": "Filipenses",
      "chapter": 3,
      "verseNumber": 14,
      "spanishTranslation": "prosigo a la meta, al premio del supremo llamamiento de Dios en Cristo Jesús.",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "PHP_3_15",
      "bookId": "PHP",
      "bookName": "Filipenses",
      "chapter": 3,
      "verseNumber": 15,
      "spanishTranslation": "Así que, todos los que somos perfectos, esto mismo sintamos; y si otra cosa sentís, esto también os lo revelará Dios.",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "PHP_3_16",
      "bookId": "PHP",
      "bookName": "Filipenses",
      "chapter": 3,
      "verseNumber": 16,
      "spanishTranslation": "Pero en aquello a que hemos llegado, sigamos una misma regla, sintamos una misma cosa.",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "PHP_3_17",
      "bookId": "PHP",
      "bookName": "Filipenses",
      "chapter": 3,
      "verseNumber": 17,
      "spanishTranslation": "Hermanos, sed imitadores de mí, y mirad a los que así se conducen según el ejemplo que tenéis en nosotros.",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "PHP_3_18",
      "bookId": "PHP",
      "bookName": "Filipenses",
      "chapter": 3,
      "verseNumber": 18,
      "spanishTranslation": "Porque por ahí andan muchos, de los cuales os dije muchas veces, y aun ahora lo digo llorando, que son enemigos de la cruz de Cristo;",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "PHP_3_19",
      "bookId": "PHP",
      "bookName": "Filipenses",
      "chapter": 3,
      "verseNumber": 19,
      "spanishTranslation": "el fin de los cuales será perdición, cuyo dios es el vientre, y cuya gloria es su vergüenza; que sólo piensan en lo terrenal.",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "PHP_3_20",
      "bookId": "PHP",
      "bookName": "Filipenses",
      "chapter": 3,
      "verseNumber": 20,
      "spanishTranslation": "Mas nuestra ciudadanía está en los cielos, de donde también esperamos al Salvador, al Señor Jesucristo;",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "PHP_3_21",
      "bookId": "PHP",
      "bookName": "Filipenses",
      "chapter": 3,
      "verseNumber": 21,
      "spanishTranslation": "el cual transformará el cuerpo de la humillación nuestra, para que sea semejante al cuerpo de la gloria suya, por el poder con el cual puede también sujetar a sí mismo todas las cosas.",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "PHP_4_1",
      "bookId": "PHP",
      "bookName": "Filipenses",
      "chapter": 4,
      "verseNumber": 1,
      "spanishTranslation": "Así que, hermanos míos amados y deseados, gozo y corona mía, estad así firmes en el Señor, amados.",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "PHP_4_2",
      "bookId": "PHP",
      "bookName": "Filipenses",
      "chapter": 4,
      "verseNumber": 2,
      "spanishTranslation": "Ruego a Evodia y a Síntique, que sean de un mismo sentir en el Señor.",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "PHP_4_3",
      "bookId": "PHP",
      "bookName": "Filipenses",
      "chapter": 4,
      "verseNumber": 3,
      "spanishTranslation": "Asimismo te ruego también a ti, compañero fiel, que ayudes a éstas que combatieron juntamente conmigo en el evangelio, con Clemente también y los demás colaboradores míos, cuyos nombres están en el libro de la vida.",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "PHP_4_4",
      "bookId": "PHP",
      "bookName": "Filipenses",
      "chapter": 4,
      "verseNumber": 4,
      "spanishTranslation": "Regocijaos en el Señor siempre. Otra vez digo: ¡Regocijaos!",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "PHP_4_5",
      "bookId": "PHP",
      "bookName": "Filipenses",
      "chapter": 4,
      "verseNumber": 5,
      "spanishTranslation": "Vuestra gentileza sea conocida de todos los hombres. El Señor está cerca.",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "PHP_4_6",
      "bookId": "PHP",
      "bookName": "Filipenses",
      "chapter": 4,
      "verseNumber": 6,
      "spanishTranslation": "Por nada estéis afanosos, sino sean conocidas vuestras peticiones delante de Dios en toda oración y ruego, con acción de gracias.",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "PHP_4_7",
      "bookId": "PHP",
      "bookName": "Filipenses",
      "chapter": 4,
      "verseNumber": 7,
      "spanishTranslation": "Y la paz de Dios, que sobrepasa todo entendimiento, guardará vuestros corazones y vuestros pensamientos en Cristo Jesús.",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "PHP_4_8",
      "bookId": "PHP",
      "bookName": "Filipenses",
      "chapter": 4,
      "verseNumber": 8,
      "spanishTranslation": "Por lo demás, hermanos, todo lo que es verdadero, todo lo honesto, todo lo justo, todo lo puro, todo lo amable, todo lo que es de buen nombre; si hay virtud alguna, si algo digno de alabanza, en esto pensad.",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "PHP_4_9",
      "bookId": "PHP",
      "bookName": "Filipenses",
      "chapter": 4,
      "verseNumber": 9,
      "spanishTranslation": "Lo que aprendisteis y recibisteis y oísteis y visteis en mí, esto haced; y el Dios de paz estará con vosotros.",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "PHP_4_10",
      "bookId": "PHP",
      "bookName": "Filipenses",
      "chapter": 4,
      "verseNumber": 10,
      "spanishTranslation": "En gran manera me gocé en el Señor de que ya al fin habéis revivido vuestro cuidado de mí; de lo cual también estabais solícitos, pero os faltaba la oportunidad.",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "PHP_4_11",
      "bookId": "PHP",
      "bookName": "Filipenses",
      "chapter": 4,
      "verseNumber": 11,
      "spanishTranslation": "No lo digo porque tenga escasez, pues he aprendido a contentarme, cualquiera que sea mi situación.",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "PHP_4_12",
      "bookId": "PHP",
      "bookName": "Filipenses",
      "chapter": 4,
      "verseNumber": 12,
      "spanishTranslation": "Sé vivir humildemente, y sé tener abundancia; en todo y por todo estoy enseñado, así para estar saciado como para tener hambre, así para tener abundancia como para padecer necesidad.",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "PHP_4_13",
      "bookId": "PHP",
      "bookName": "Filipenses",
      "chapter": 4,
      "verseNumber": 13,
      "spanishTranslation": "Todo lo puedo en Cristo que me fortalece.",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "PHP_4_14",
      "bookId": "PHP",
      "bookName": "Filipenses",
      "chapter": 4,
      "verseNumber": 14,
      "spanishTranslation": "Sin embargo, bien hicisteis en participar conmigo en mi tribulación.",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "PHP_4_15",
      "bookId": "PHP",
      "bookName": "Filipenses",
      "chapter": 4,
      "verseNumber": 15,
      "spanishTranslation": "Y sabéis también vosotros, oh filipenses, que al principio de la predicación del evangelio, cuando partí de Macedonia, ninguna iglesia participó conmigo en razón de dar y recibir, sino vosotros solos;",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "PHP_4_16",
      "bookId": "PHP",
      "bookName": "Filipenses",
      "chapter": 4,
      "verseNumber": 16,
      "spanishTranslation": "pues aun a Tesalónica me enviasteis una y otra vez para mis necesidades.",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "PHP_4_17",
      "bookId": "PHP",
      "bookName": "Filipenses",
      "chapter": 4,
      "verseNumber": 17,
      "spanishTranslation": "No es que busque dádivas, sino que busco fruto que abunde en vuestra cuenta.",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "PHP_4_18",
      "bookId": "PHP",
      "bookName": "Filipenses",
      "chapter": 4,
      "verseNumber": 18,
      "spanishTranslation": "Pero todo lo he recibido, y tengo abundancia; estoy lleno, habiendo recibido de Epafrodito lo que enviasteis; olor fragante, sacrificio acepto, agradable a Dios.",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "PHP_4_19",
      "bookId": "PHP",
      "bookName": "Filipenses",
      "chapter": 4,
      "verseNumber": 19,
      "spanishTranslation": "Mi Dios, pues, suplirá todo lo que os falta conforme a sus riquezas en gloria en Cristo Jesús.",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "PHP_4_20",
      "bookId": "PHP",
      "bookName": "Filipenses",
      "chapter": 4,
      "verseNumber": 20,
      "spanishTranslation": "Al Dios y Padre nuestro sea gloria por los siglos de los siglos. Amén.",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "PHP_4_21",
      "bookId": "PHP",
      "bookName": "Filipenses",
      "chapter": 4,
      "verseNumber": 21,
      "spanishTranslation": "Saludad a todos los santos en Cristo Jesús. Los hermanos que están conmigo os saludan.",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "PHP_4_22",
      "bookId": "PHP",
      "bookName": "Filipenses",
      "chapter": 4,
      "verseNumber": 22,
      "spanishTranslation": "Todos los santos os saludan, y especialmente los de la casa de César.",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    },
    {
      "id": "PHP_4_23",
      "bookId": "PHP",
      "bookName": "Filipenses",
      "chapter": 4,
      "verseNumber": 23,
      "spanishTranslation": "La gracia de nuestro Señor Jesucristo sea con todos vosotros. Amén.",
      "isCompleted": true,
      "lastModified": "2025-01-01T00:00:00.000",
      "isRedLetter": false
    }
  ]
}